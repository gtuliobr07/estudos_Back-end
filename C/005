#include <stdio.h>

int main(){
    int idade, matricular;
    float altura;
    char nome[50];

    printf("Digite seu nome? \n");
    scanf("%s", nome);

    printf("Digite sua idade? \n");
    scanf("%d", &idade);

    printf("Digite sua altura? \n");
    scanf("%f", &altura);

    printf("Digite sua matricular? \n");
    scanf("%d", &matricular);

    printf("Nome do Aluno: %s - Matricula: %d \n", nome, matricular);
    printf("Idade do Aluno: %d - Altura: %f", idade, altura);

    return 0;

}
